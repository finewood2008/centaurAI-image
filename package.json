{
  "name": "centaur-ai-graphics-workbench",
  "private": true,
  "version": "0.6.10",
  "type": "module",
  "main": "electron/main.cjs",
  "description": "半人马 AI 图形工作台 — Centaur Image Studio",
  "author": "CentaurAI (centaurloop.com)",
  "scripts": {
    "dev": "vite",
    "mock:api": "node scripts/mock-image-api.mjs",
    "build": "tsc -b && vite build",
    "deploy:cf": "npm run build && wrangler deploy",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "com.centaurai.imagestudio",
    "productName": "CentaurImageStudio",
    "asar": false,
    "directories": { "output": "release" },
    "files": ["electron/**/*", "dist/**/*", "package.json"],
    "win": { "target": "nsis", "artifactName": "CentaurImageStudio-windows-${arch}.${ext}" },
    "nsis": { "oneClick": true, "perMachine": false },
    "mac": { "target": "dmg", "artifactName": "CentaurImageStudio-macos-${arch}.${ext}" },
    "linux": { "target": "AppImage", "artifactName": "CentaurImageStudio-linux-${arch}.${ext}", "category": "Graphics" }
  },
  "dependencies": {
    "@fal-ai/client": "^1.10.0",
    "@streamdown/math": "^1.0.2",
    "core-js": "^3.49.0",
    "fflate": "^0.8.2",
    "katex": "^0.16.47",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "streamdown": "^2.5.0",
    "zustand": "^5.0.5"
  },
  "overrides": {
    "mdast-util-gfm-autolink-literal": "2.0.0",
    "dompurify": "^3.4.7"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.8.3",
    "vite": "^6.3.2",
    "vitest": "^4.1.5",
    "wrangler": "^4.96.0"
  }
}
